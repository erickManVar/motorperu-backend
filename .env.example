# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/motorperu?sslmode=require

# Redis (Railway)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
BETTER_AUTH_SECRET=your-better-auth-secret

# Culqi (Pagos Peru)
CULQI_PUBLIC_KEY=pk_test_xxx
CULQI_SECRET_KEY=sk_test_xxx

# Resend (Emails)
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@motorperu.com

# URLs
FRONTEND_URL=https://motorperu.com
BACKOFFICE_URL=https://admin.motorperu.com
PORT=4000

# Cloudflare R2 (Imagenes)
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=motorperu
R2_PUBLIC_URL=https://images.motorperu.com
